<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Show DEBUG for the client under test so connection events are visible -->
    <logger name="io.axoniq.platform.framework.client" level="DEBUG"/>

    <!-- Suppress noisy RSocket / Reactor Netty internals -->
    <logger name="io.rsocket" level="WARN"/>
    <logger name="reactor.netty" level="WARN"/>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
